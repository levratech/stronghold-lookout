{
	"version": "v4-handshake",
	"token_sources": [
		{ "type": "authorization_header", "prefix": "Bearer " },
		{ "type": "cookie", "name": "stronghold_token" }
	],
	"jwt": {
		"validation_mode": "static_jwks_rs256",
		"algorithm": "RS256",
		"issuer": "stronghold-sentry",
		"audience": ["aegis"],
		"keys": [
			{
				"kid": "${GATEWAY_JWT_KEY_ID}",
				"algorithm": "RS256",
				"public_key_pem": "${GATEWAY_JWT_PUBLIC_KEY_PEM}"
			}
		]
	},
	"trusted_proxy": {
		"enabled": true,
			"trusted_sources": ["${TRUSTED_PROXY_CIDR_1}", "${TRUSTED_PROXY_CIDR_2}"]
	},
	"resolution_mode": "token",
	"interfaces": [
		{
			"pattern": "levra.tech",
			"match": {
				"interface_id": "levra",
				"domain": "levra.tech",
				"enabled": true
			}
		}
	],
	"assets": [
		{
			"methods": ["GET", "HEAD"],
			"match": {
				"asset_id": "drawbridge-auth-session",
				"interface_id": "levra",
				"matched_path_pattern": "/_/auth/session",
				"path_match_type": "exact",
				"priority": 200,
				"upstream_target": "http://drawbridge:3000",
				"auth_mode": "jwt",
				"identity_headers": {
					"X-Aegis-Principal": "{principal_id}",
					"X-Aegis-Context": "{context_id}",
					"X-Aegis-Realm": "{realm_id}",
					"X-Aegis-Badges": "{badge_ids}"
				},
				"headers": {
					"X-Stronghold-Domain-ID": "${ROOT_DOMAIN_ID}",
					"X-Stronghold-Interface-ID": "levra"
				},
				"enabled": true
			}
		},
		{
			"methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "HEAD", "OPTIONS"],
			"match": {
				"asset_id": "drawbridge-auth",
				"interface_id": "levra",
				"matched_path_pattern": "/_/auth/",
				"path_match_type": "prefix",
				"priority": 100,
				"upstream_target": "http://drawbridge:3000",
				"auth_mode": "public",
				"headers": {
						"X-Stronghold-OAuth-Client-ID": "${GOOGLE_CLIENT_ID}",
						"X-Stronghold-OAuth-Secret": "${GOOGLE_CLIENT_SECRET}",
					"X-Stronghold-OAuth-Auth-URL": "https://accounts.google.com/o/oauth2/v2/auth",
					"X-Stronghold-OAuth-Token-URL": "https://oauth2.googleapis.com/token",
						"X-Stronghold-Domain-ID": "${ROOT_DOMAIN_ID}"
				},
				"enabled": true
			}
		},
		{
			"methods": ["GET"],
			"match": {
				"asset_id": "levra-nats-ws",
				"interface_id": "levra",
				"matched_path_pattern": "/_/nats",
				"path_match_type": "exact",
				"priority": 190,
				"upstream_target": "http://nats:8443",
				"auth_mode": "jwt",
				"websocket_mode": "require",
				"path_transform": {
					"strip_prefix": "/_/nats"
				},
				"enabled": true
			}
		},
		{
			"methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "HEAD", "OPTIONS"],
			"match": {
				"asset_id": "levra-all",
				"interface_id": "levra",
				"matched_path_pattern": "/",
				"path_match_type": "prefix",
				"upstream_target": "http://sentry:8081",
				"auth_mode": "jwt",
				"enabled": true
			}
		}
	]
}
